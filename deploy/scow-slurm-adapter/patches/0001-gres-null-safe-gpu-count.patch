+// GresGpuPerNodeCount parses `scontrol show node` and returns per-node GPU count as a decimal string.
+// When Slurm reports Gres=(null), the historical `grep … | awk …` pipeline can exit non-zero (awk error) and break RPCs.
+func GresGpuPerNodeCount(node string) (string, error) {
+	out, err := RunCommand(fmt.Sprintf("scontrol show node=%s", node))
+	if err != nil {
+		return "", err
+	}
+	if CheckSlurmStatus(out) {
+		return "", fmt.Errorf("slurm error in scontrol output")
+	}
+	for _, raw := range strings.Split(out, "\n") {
+		line := strings.TrimSpace(raw)
+		if !strings.HasPrefix(line, "Gres=") {
+			continue
+		}
+		val := strings.TrimSpace(strings.TrimPrefix(line, "Gres="))
+		if val == "(null)" {
+			return "0", nil
+		}
+		if strings.HasPrefix(val, "gpu:") {
+			num := strings.TrimPrefix(val, "gpu:")
+			digits := ""
+			for _, r := range num {
+				if r >= '0' && r <= '9' {
+					digits += string(r)
+				} else {
+					break
+				}
+			}
+			if digits == "" {
+				return "0", nil
+			}
+			return digits, nil
+		}
+		parts := strings.Split(val, ":")
+		for i := len(parts) - 1; i >= 0; i-- {
+			p := strings.TrimSpace(parts[i])
+			if p == "" {
+				continue
+			}
+			if n, e := strconv.Atoi(p); e == nil && n >= 0 {
+				return strconv.Itoa(n), nil
+			}
+		}
+		return "0", nil
+	}
+	return "0", nil
+}
